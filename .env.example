# ===== TickFlow =====
# 留空或不填则启用 Free 试用模式(TickFlow.free()),仅能拿历史日 K 单股数据
TICKFLOW_API_KEY=

# ===== Data Provider =====
# 启动默认值。也可在 设置 > 系统设置 > 数据源 中保存并立即切换。
# tickflow: 保持原 TickFlow 数据源; akshare: 免费盘后日线模式(手动同步)
DATA_PROVIDER=tickflow
FALLBACK_PROVIDER=baostock
AKSHARE_INITIAL_YEARS=3
AKSHARE_MAX_WORKERS=8
AKSHARE_WRITE_BATCH_SIZE=64

# ===== AI(可选,留空跳过 AI 功能) =====
AI_PROVIDER=openai_compat          # openai_compat | ollama
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=
AI_MODEL=deepseek-chat
AI_DAILY_TOKEN_BUDGET=500000

# ===== Server =====
HOST=0.0.0.0
PORT=3018
LOG_LEVEL=INFO

# ===== Data =====
DATA_DIR=./data
